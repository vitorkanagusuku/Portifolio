<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true"
    tools:context=".ui.lobby.LobbyFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- Cabeçalho -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚪 Sala de Espera"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aguardando jogadores entrarem na sala"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Card: Código da Sala -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRoomCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/accent_yellow"
            app:strokeWidth="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvRoomCodeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compartilhe este código:"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <!-- Código grande e destacado -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvRoomCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ABCD12"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_yellow"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0.3"
                        tools:text="XKCD42" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyCode"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="22sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Envie para seus amigos entrarem!"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Jogadores -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/white_20"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Cabeçalho dos jogadores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👥 Jogadores"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:id="@+id/tvPlayerCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/6 jogadores"
                        android:textSize="12sp"
                        android:textColor="@color/accent_cyan"
                        android:background="@drawable/bg_score_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />

                </LinearLayout>

                <!-- Lista de jogadores -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPlayers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Como Jogar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Como Jogar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_cyan"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Todos entram na videochamada automaticamente\n2. Um enigma aparece na tela de todos\n3. Discutam em grupo e resolvam juntos!\n4. Quem acertar ganha pontos extras\n5. Completem todos os enigmas no menor tempo!"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Área de ações -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Barra de progresso de carregamento -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:indeterminate="true"
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                android:indeterminateTint="@color/colorPrimary" />

            <!-- Botão de pronto -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReady"
                style="@style/Widget.EscapeCall.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Marcar como Pronto"
                android:layout_marginBottom="12dp" />

            <!-- Botão de iniciar (apenas host) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartGame"
                style="@style/Widget.EscapeCall.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="▶  Iniciar Jogo!"
                android:textSize="18sp"
                android:visibility="gone" />

            <!-- Mensagem para não-host -->
            <TextView
                android:id="@+id/tvWaitingForHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ Aguardando o host iniciar o jogo…"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
