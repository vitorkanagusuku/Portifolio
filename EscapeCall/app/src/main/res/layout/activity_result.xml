<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true"
    tools:context=".ui.result.ResultActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Título da tela -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏁 Resultado Final"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Card: Classificação de Performance -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/accent_yellow"
            app:strokeWidth="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Emoji da classificação -->
                <TextView
                    android:id="@+id/tvRatingEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆"
                    android:textSize="64sp" />

                <!-- Título da classificação -->
                <TextView
                    android:id="@+id/tvRatingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excelente!"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_yellow"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginTop="8dp" />

                <!-- Descrição -->
                <TextView
                    android:id="@+id/tvRatingDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parabéns! Todos os enigmas resolvidos!"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

                <!-- Mensagem especial (apenas para 100%) -->
                <TextView
                    android:id="@+id/tvSpecialMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏆 Todos os enigmas resolvidos! Incrível trabalho em equipe!"
                    android:textSize="13sp"
                    android:textColor="@color/accent_yellow"
                    android:gravity="center"
                    android:background="@drawable/bg_score_badge"
                    android:padding="10dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <!-- Código da sala -->
                <TextView
                    android:id="@+id/tvRoomCodeResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sala: ABCD12"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Pontuação Total -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/white_20"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pontuação Total"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvTotalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="450"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_yellow"
                        android:fontFamily="@font/montserrat_bold" />

                    <TextView
                        android:id="@+id/tvScoreLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" pts"
                        android:textSize="20sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

                <!-- Barra de progresso de conclusão -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressCompletion"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="8dp"
                    app:trackColor="@color/surface_card"
                    app:indicatorColor="@color/success_green"
                    app:trackCornerRadius="5dp"
                    android:progress="100"
                    android:max="100" />

                <TextView
                    android:id="@+id/tvCompletionPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100% concluído"
                    android:textSize="12sp"
                    android:textColor="@color/success_green"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Estatísticas -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/white_20"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Estatísticas"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="16dp" />

                <!-- Linha de stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Enigmas resolvidos -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_primary"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧩"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/tvPuzzlesSolved"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3/3"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/montserrat_bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enigmas"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- Tempo total -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_primary"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱️"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/tvTimeElapsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04:32"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/montserrat_bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tempo"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- Jogador -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_primary"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/tvPlayerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ana"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="@font/montserrat_bold"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jogador"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Botões de ação -->
        <LinearLayout
            android:id="@+id/layoutButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Jogar novamente -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAgain"
                style="@style/Widget.EscapeCall.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🔄  Jogar Novamente"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Compartilhar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/Widget.EscapeCall.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📤  Compartilhar Resultado"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <!-- Voltar ao início -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHome"
                style="@style/Widget.EscapeCall.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🏠  Início"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
