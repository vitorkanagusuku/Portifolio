<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ─── Tema Principal do App ─────────────────────────────────────────────── -->
    <style name="Theme.EscapeCall" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Cores primárias -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Cores secundárias -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>

        <!-- Fundo e superfície -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>

        <!-- Erros -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Tipografia -->
        <item name="android:fontFamily">@font/montserrat_regular</item>
        <item name="fontFamily">@font/montserrat_regular</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.EscapeCall.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.EscapeCall.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.EscapeCall.LargeComponent</item>

        <!-- Estilos de componentes -->
        <item name="materialCardViewStyle">@style/Widget.EscapeCall.CardView</item>
        <item name="materialButtonStyle">@style/Widget.EscapeCall.Button</item>
        <item name="textInputStyle">@style/Widget.EscapeCall.TextInputLayout</item>
    </style>

    <!-- ─── Tema da Splash Screen ─────────────────────────────────────────────── -->
    <style name="Theme.EscapeCall.Splash" parent="Theme.EscapeCall">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <!-- ─── Tema para Diálogos ────────────────────────────────────────────────── -->
    <style name="Theme.EscapeCall.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSurface">@color/card_elevated</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/card_elevated</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.EscapeCall.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.EscapeCall.Button.Dialog.Outline</item>
    </style>

    <!-- ─── Shapes ────────────────────────────────────────────────────────────── -->
    <style name="ShapeAppearance.EscapeCall.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.EscapeCall.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.EscapeCall.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ─── CardView ──────────────────────────────────────────────────────────── -->
    <style name="Widget.EscapeCall.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/white_20</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ─── Botões ────────────────────────────────────────────────────────────── -->
    <style name="Widget.EscapeCall.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="rippleColor">@color/white_20</item>
    </style>

    <style name="Widget.EscapeCall.Button.Primary" parent="Widget.EscapeCall.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
    </style>

    <style name="Widget.EscapeCall.Button.Secondary" parent="Widget.EscapeCall.Button">
        <item name="backgroundTint">@color/accent_yellow</item>
        <item name="android:textColor">@color/background_dark</item>
    </style>

    <style name="Widget.EscapeCall.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
    </style>

    <style name="Widget.EscapeCall.Button.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.EscapeCall.Button.Dialog.Outline" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ─── TextInputLayout ───────────────────────────────────────────────────── -->
    <style name="Widget.EscapeCall.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="boxBackgroundColor">@color/surface_card</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="errorTextColor">@color/error_red</item>
    </style>

    <!-- ─── Textos ────────────────────────────────────────────────────────────── -->
    <style name="TextAppearance.EscapeCall.Title" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.EscapeCall.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="TextAppearance.EscapeCall.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.EscapeCall.Code" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textColor">@color/accent_yellow</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.2</item>
    </style>

</resources>
